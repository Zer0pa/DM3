  "project_contract": {
    "schema_version": 1,
    "scope": {
      "question": "Can a source-backed DM3 geometry-first substrate be reconstructed and falsified from recoverable evidence only, then reproduced across Mac host and RM10 Pro execution lanes without relying on unrecovered hybrid source?",
      "in_scope": [
        "Map the manifesto's numbered T01-T236 references to executable evidence or explicit gaps",
        "Replay the recoverable October and Genesis deterministic substrate from source",
        "Define the authority metric and minimal restart battery before any hybrid rebuild",
        "Establish a RM10 Pro device replay lane with receipts and Comet metadata",
        "Falsify or retain manifesto claims based on source-backed replay evidence"
      ],
      "out_of_scope": [
        "Declaring the newer hybrid DM3 layer recovered",
        "Treating manifesto prose as executable proof",
        "Using visual geometry demos or aesthetic coherence as success",
        "Rebuilding GPU, HRM, scar-engine, or micro-transformer layers before baseline replay and authority-gate definition"
      ],
      "unresolved_questions": [
        "Which manifesto Txx labels map one-to-one to recovered executable protocols or ledgers?",
        "Which claims belong only to the unrecovered hybrid layer?",
        "What is the minimal authority metric beyond deterministic replay?",
        "What is the narrowest source-backed battery the RM10 Pro must reproduce?"
      ]
    },
    "context_intake": {
